#include <bits/stdc++.h>
using namespace std;
using ull = unsigned long long;
using ll = long long;

int main(){
    ios::sync_with_stdio(0);
    cin.tie(0);

    int n, k;
    cin >> n >> k;

    ull sum = 0;
    ll i = 1, j = 0;

    while (true){
        ll cells = 4 * (n + j);
        if ((k - cells) > 0){
            k -= cells;
            sum += i * cells;
            i++;
            j++;
        } else {
            sum += i * k;
            break;
        }
    }
    cout << sum;
}
